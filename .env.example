# ============================================================
#  MODÈLE de variables d'environnement (SANS secrets)
#  Copie ce fichier en « .env.local » et remplis les valeurs.
#  .env.local n'est JAMAIS versionné (voir .gitignore).
# ============================================================

# --- Base de données (P2) ---
# URI de connexion MongoDB Atlas (cluster gratuit M0)
MONGODB_URI=

# --- Paiement Stripe (P4) — mode test au début ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Authentification / Auth.js (P5) ---
# Générer un secret : `openssl rand -base64 32`
AUTH_SECRET=
# URL du site (http://localhost:3000 en local)
AUTH_URL=http://localhost:3000
# Connexion Google (optionnelle)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Emails / Resend (P5) ---
RESEND_API_KEY=
# Expéditeur (sans domaine vérifié : "Nūr <onboarding@resend.dev>")
EMAIL_FROM=
# Adresse du propriétaire (reçoit une notification à chaque commande)
OWNER_EMAIL=

# --- Images / Cloudinary (P6, optionnel) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
