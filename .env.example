# ============================================================
#  MODÈLE de variables d'environnement (SANS secrets)
#  Copie ce fichier en « .env.local » et remplis les valeurs.
#  .env.local n'est JAMAIS versionné (voir .gitignore).
# ============================================================

# --- Base de données (P2) ---
# URI de connexion MongoDB Atlas (cluster gratuit M0)
MONGODB_URI=

# --- Paiement Stripe (P4) — mode test au début ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Authentification clients ---
# Clé de signature des sessions clients. Générer : `openssl rand -base64 32`
AUTH_SECRET=

# --- Emails / Resend (P5) ---
RESEND_API_KEY=
# Expéditeur (sans domaine vérifié : "Nūr <onboarding@resend.dev>")
EMAIL_FROM=
# Adresse du propriétaire (reçoit une notification à chaque commande)
OWNER_EMAIL=

# --- Back-office admin (P6) ---
# Mot de passe de connexion à /admin (choisir une valeur longue et aléatoire)
ADMIN_PASSWORD=

# --- Images / Cloudinary (P6, optionnel) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
